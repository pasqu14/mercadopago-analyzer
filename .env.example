# =============================================
# MERCADO PAGO ANALYSIS - Variables de entorno
# =============================================

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx-xxxx   # Tu Access Token de MP (test o prod)

# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/mercadopago?sslmode=require

# IA - Anthropic Claude (principal)
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# IA - Google Gemini (fallback, opcional)
GEMINI_API_KEY=AIzaSyXXXX

# Servidor
PORT=3000
NODE_ENV=development

# Seguridad (genera con: openssl rand -hex 32)
API_SECRET=tu_clave_secreta_aqui

# Render (opcional, para triggers remotos)
RENDER_API_KEY=rnd_xxxx
RENDER_SERVICE_ID=srv-xxxx
